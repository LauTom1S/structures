#include <iostream>
#include <string>
#include <locale>
#include <fstream>
using namespace std;
int main()
{
    setlocale(LC_ALL, "ru");
    char currentSymbol;
    int k[] = { 7,4,2,1,3,6,5 };
    int N = 7;
    int cycles = 0;
    int sizeOfCryptedText;
    int changedChars;
    string readedFileText;       
    cout << "Метод блочной перестановки\n";
    cout << "k = {7, 4, 2, 1, 3, 6, 5}\n";
    cout << "N = 7\n";
    string cryptedText;
    fstream text;
    text.open("crypted.txt");

    if (text)
    {
        while (text.get(currentSymbol))
        {
            cryptedText += currentSymbol;
        }
    }
    text.close();
    cout << endl;
    cout << "Зашифрованный текст: " << cryptedText << "\n";
    while (cryptedText.size() % N != 0) {
        cryptedText = cryptedText + ' ';
    }
    string decryptedText(size(cryptedText), ' ');
    sizeOfCryptedText = cryptedText.size();
    cycles = 0;
    changedChars = 0;
    while (changedChars != sizeOfCryptedText) {
        for (int j = 0; j < N; j++) {
            decryptedText[j + 7 * cycles] = cryptedText[k[j] - 1 + 7 * cycles];
            changedChars += 1;
        }
        cycles += 1;
    }
    cout << "Расшифрованный текст: " << decryptedText << "\n";
}
